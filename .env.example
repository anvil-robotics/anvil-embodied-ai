# ROS2 distributed inference environment
# Copy to .env and edit for your setup:  cp .env.example .env

# ROS domain ID — must match the Robot PC. Leave empty for localhost-only mode.
ROS_DOMAIN_ID=1

# CycloneDDS middleware (required for cross-machine discovery)
RMW_IMPLEMENTATION=rmw_cyclonedds_cpp
CYCLONEDDS_URI=file:///workspace/configs/cyclonedds/gpu_pc.xml

# Model path inside the container (model_zoo/ is mounted read-only)
# For testing: /workspace/model_zoo/test/pretrained_model
MODEL_PATH=/workspace/model_zoo/my_model
CONFIG_FILE=/workspace/configs/lerobot_control/inference_default.yaml

# Docker image tag (used by docker-compose.yml)
IMAGE_TAG=latest

# lerobot version pinned in the Docker image
LEROBOT_VERSION=0.5.0

# Optional lerobot extras — comma-separated, empty for ACT/Diffusion (no extras needed)
# Rebuild the image after changing this:  docker compose build
# Examples:
#   smolvla              → for SmolVLA inference
#   smolvla,peft         → SmolVLA + LoRA fine-tuned models
LEROBOT_EXTRAS=

# Set to true to skip model loading and just monitor FPS (for testing DDS connectivity)
MONITOR_ONLY=false
